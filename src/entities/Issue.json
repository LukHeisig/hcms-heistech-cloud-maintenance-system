{
  "name": "Issue",
  "type": "object",
  "properties": {
    "control_point_id": {
      "type": "string",
      "description": "ID kontroln\u00edho bodu"
    },
    "description": {
      "type": "string",
      "description": "Popis z\u00e1vady"
    },
    "photo_url": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "reported",
        "resolved"
      ],
      "default": "reported",
      "description": "Stav z\u00e1vady"
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time",
      "description": "Datum vy\u0159e\u0161en\u00ed"
    },
    "resolved_by": {
      "type": "string",
      "description": "Email u\u017eivatele, kter\u00fd vy\u0159e\u0161il z\u00e1vadu"
    },
    "resolution_note": {
      "type": "string",
      "description": "Pozn\u00e1mka k vy\u0159e\u0161en\u00ed"
    }
  },
  "required": [
    "control_point_id",
    "description"
  ]
}