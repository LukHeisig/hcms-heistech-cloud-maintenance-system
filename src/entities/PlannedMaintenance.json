{
  "name": "PlannedMaintenance",
  "type": "object",
  "properties": {
    "machine_id": {
      "type": "string",
      "description": "ID stroje"
    },
    "title": {
      "type": "string",
      "description": "N\u00e1zev pl\u00e1novan\u00e9 \u00fadr\u017eby"
    },
    "description": {
      "type": "string",
      "description": "Detailn\u00ed popis pr\u00e1ce"
    },
    "maintenance_type": {
      "type": "string",
      "enum": [
        "preventive",
        "corrective",
        "predictive",
        "inspection"
      ],
      "description": "Typ \u00fadr\u017eby"
    },
    "planned_date": {
      "type": "string",
      "format": "date",
      "description": "Pl\u00e1novan\u00e9 datum proveden\u00ed"
    },
    "assigned_to": {
      "type": "string",
      "format": "email",
      "description": "Email p\u0159i\u0159azen\u00e9ho technika"
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "assigned",
        "completed",
        "cancelled"
      ],
      "default": "planned",
      "description": "Stav \u00fakolu"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "default": "medium",
      "description": "Priorita"
    },
    "estimated_duration_hours": {
      "type": "number",
      "description": "Odhadovan\u00e1 doba trv\u00e1n\u00ed v hodin\u00e1ch"
    },
    "estimated_cost": {
      "type": "number",
      "description": "Odhadovan\u00e9 n\u00e1klady v K\u010d"
    },
    "interval_days": {
      "type": "number",
      "description": "Interval opakov\u00e1n\u00ed v dnech (pro opakovan\u00e9 \u00fakoly)"
    },
    "notes": {
      "type": "string",
      "description": "Pozn\u00e1mky"
    },
    "work_order_created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Kdy byl vytvo\u0159en pracovn\u00ed p\u0159\u00edkaz"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Kdy byl \u00fakol dokon\u010den"
    },
    "maintenance_record_id": {
      "type": "string",
      "description": "ID vytvo\u0159en\u00e9ho MaintenanceRecord po dokon\u010den\u00ed"
    }
  },
  "required": [
    "machine_id",
    "title",
    "maintenance_type",
    "planned_date"
  ]
}